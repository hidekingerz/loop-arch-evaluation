{
  "name": "loop-arch-evaluation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Single-agent closed loop verification harness (TDD green-ization on frontend code)",
  "scripts": {
    "typecheck": "tsc --noEmit",
